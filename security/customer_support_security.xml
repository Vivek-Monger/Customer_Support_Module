<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Security Category -->
        <record id="module_category_customer_support" model="ir.module.category">
            <field name="name">Customer Support</field>
            <field name="sequence">10</field>
        </record>

        <!-- Support Groups -->
        <record id="group_support_customer" model="res.groups">
            <field name="name">Support Customer</field>
            <field name="category_id" ref="module_category_customer_support"/>
        </record>

        <record id="group_support_agent" model="res.groups">
            <field name="name">Support Agent</field>
            <field name="category_id" ref="module_category_customer_support"/>
            <field name="implied_ids" eval="[(4, ref('customer_support_module.group_support_customer'))]"/>
        </record>

        <record id="group_support_manager" model="res.groups">
            <field name="name">Support Manager</field>
            <field name="category_id" ref="module_category_customer_support"/>
            <field name="implied_ids" eval="[(4, ref('customer_support_module.group_support_agent'))]"/>
        </record>

        <record id="group_support_admin" model="res.groups">
            <field name="name">Support Admin</field>
            <field name="category_id" ref="module_category_customer_support"/>
            <field name="implied_ids" eval="[
                (4, ref('customer_support_module.group_support_manager'))
            ]"/>
        </record>
    </data>
</odoo>